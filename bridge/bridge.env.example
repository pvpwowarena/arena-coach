# Arena Bridge — пример конфигурации
# Скопируй этот файл как bridge.env рядом с arena-bridge.exe
# и заполни значения (токен и URL выдаёт администратор).

# ── Обязательные ────────────────────────────────────────────────────────────

# Полный путь к папке WoW (папка содержит подпапку Logs/)
# Windows:
WOW_INSTALL_PATH=C:\Program Files (x86)\World of Warcraft\_classic_era_
# macOS (раскомментировать если нужно):
# WOW_INSTALL_PATH=/Applications/World of Warcraft/_classic_era_

# URL backend'а (выдаётся администратором)
BACKEND_URL=https://coach.example.com

# Bearer-токен (выдаётся при /access add в Discord)
BRIDGE_BEARER_TOKEN=paste-your-token-here

# Точное имя WoW-персонажа (регистр важен — как в игре)
BRIDGE_PLAYER_NAME=YourCharacterName

# ── Опциональные ─────────────────────────────────────────────────────────────

# Интервал опроса chat-лога в секундах (default: 0.5)
# BRIDGE_POLL_INTERVAL=0.5

# Уровень логирования: DEBUG / INFO / WARNING / ERROR (default: INFO)
# LOG_LEVEL=INFO
