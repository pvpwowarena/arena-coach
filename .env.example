# Скопируй в .env и заполни. .env в .gitignore — никогда не коммитим.
# Этот файл — single source of truth для всех ENV-переменных проекта.

# ────────────────────────────── Discord ──────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# CSV дискорд-ID владельцев (всегда admin, нельзя удалить через /access remove)
ARENA_COACH_OWNER_DISCORD_IDS=

# ────────────────────────────── Anthropic ────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_SYNTH=claude-sonnet-4-6
ANTHROPIC_MODEL_CLASSIFY=claude-haiku-4-5-20251001

# ────────────────────────────── Storage ──────────────────────────────
DATABASE_URL=sqlite:////var/lib/arena-coach/coach.db
KB_PATH=/var/lib/arena-coach/kb
AUDIT_LOG_DIR=/var/lib/arena-coach/audit

# ────────────────────────────── Crypto ───────────────────────────────
# 32-байтный Fernet-ключ. Генерация:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ARENA_COACH_FERNET_KEY=
# Опционально: предыдущий ключ при ротации (для дешифровки старых записей)
ARENA_COACH_FERNET_PREV_KEY=

# ────────────────────────────── WSS / bridge ─────────────────────────
WSS_BIND=127.0.0.1:8765
WSS_PUBLIC_URL=wss://coach.example.com/ws
# Bearer-токен выдаётся per-player при /access add. Bridge у конкретного игрока хранит его в своём .env
BRIDGE_BEARER_TOKEN=

# ────────────────────────────── Ops ──────────────────────────────────
LOG_LEVEL=INFO
SENTRY_DSN=
