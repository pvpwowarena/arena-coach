# Reverse-proxy для Arena Coach API.
# Caddy автоматически получает TLS-сертификат через Let's Encrypt.

coach.example.com {
    encode gzip zstd

    # WSS endpoint для bridge'ей
    handle_path /ws/* {
        reverse_proxy 127.0.0.1:8000
    }

    # REST API (admin tooling)
    handle_path /v1/* {
        reverse_proxy 127.0.0.1:8000
    }

    # Health
    handle_path /health {
        reverse_proxy 127.0.0.1:8000
    }

    # Всё остальное — 404
    handle {
        respond "Not Found" 404
    }

    log {
        output file /var/log/caddy/coach.log
        format json
    }
}
